nected_home&gt;&gt;https://store.google.com/intl/en/ideas/articles/google-home-app-updates/" data-tracking-url="https://store.google.com/intl/en/ideas/articles/google-home-app-updates/"><div data-component-name="box" class="gQjUFd NGrerf fXTCsc UiYyRd" style="padding:8px;border-radius:24px"><article class="ri9Fr"><aside class="oTSVsc"><span class="BhjvRe">Google Home App</span><span class="eUe8V">The redesigned Google Home app makes it easier to control your smart home devices, wherever you are.</span></aside><aside class="oTSVsc"><span class="rIbWHd"><img src="https://lh3.googleusercontent.com/sBnuaW-Es87DpbyRqX8Ubt3nMOlmSvqWdm0sR7JTvIVLlKsLNEL7O53nh3DaVSVNwfYtsPWyYjTa62oHQb1BwYa5ylGRY4ibf5N2" alt="Google Home App" class="JpItMb"/></span></aside></article></div></a></li><li class="TIlrKb" ssk='12:Connectivity'><a href="https://store.google.com/intl/en/ideas/articles/matter-thread-for-your-smart-home/" jsaction="click:ufFX6e;" class="sWgry" aria-label="Connectivity" data-tracking-module-name="mobile-nav-tray-section-Discover" data-tracking-label="section-detailed:Connectivity:1" data-tracking-index="1" data-tracking-action="/category/connected_home&gt;&gt;https://store.google.com/intl/en/ideas/articles/matter-thread-for-your-smart-home/" data-tracking-url="https://store.google.com/intl/en/ideas/articles/matter-thread-for-your-smart-home/"><div data-component-name="box" class="gQjUFd NGrerf fXTCsc UiYyRd" style="padding:8px;border-radius:24px"><article class="ri9Fr"><aside class="oTSVsc"><span class="BhjvRe">Connectivity</span><span class="eUe8V">Making your home more helpful with Matter</span></aside><aside class="oTSVsc"><span class="rIbWHd"><img src="https://lh3.googleusercontent.com/tJWjY9MgI7H7OYxdeOsPnR9gsc4opButeueEsUo-HFjjNdc1tyJGUieKJBTcOvs4JudqEt2Hxm0kLzG4_vwxRszLIqcizMMG8DA" alt="Connectivity" class="JpItMb"/></span></aside></article></div></a></li><li class="TIlrKb" ssk='12:Pixel Tablet'><a href="https://store.google.com/intl/en/ideas/articles/new-google-pixel-tablet/" jsaction="click:ufFX6e;" class="sWgry" aria-label="Pixel Tablet" data-tracking-module-name="mobile-nav-tray-section-Discover" data-tracking-label="section-detailed:Pixel Tablet:2" data-tracking-index="2" data-tracking-action="/category/connected_home&gt;&gt;https://store.google.com/intl/en/ideas/articles/new-google-pixel-tablet/" data-tracking-url="https://store.google.com/intl/en/ideas/articles/new-google-pixel-tablet/"><div data-component-name="box" class="gQjUFd NGrerf fXTCsc UiYyRd" style="padding:8px;border-radius:24px"><article class="ri9Fr"><aside class="oTSVsc"><span class="BhjvRe">Pixel Tablet</span><span class="eUe8V">With the Pixel Tablet on its Charging Speaker Dock, it’s easy to keep an eye on the front door, adjust your home’s temperature, and ask Google Assistant for hands-free help.</span></aside><aside class="oTSVsc"><span class="rIbWHd"><img src="https://lh3.googleusercontent.com/7q3a6NXfEwkz-134DEo7AWyG8Qxr9xlufasQCoGjSruKofj2MtMJrqMPsda8xORK9Te6rwn-aw5CmvrZLJeUU7zqeIC4ojqgGQ" alt="Pixel Tablet" class="JpItMb"/></span></aside></article></div></a></li><li class="TIlrKb" ssk='16:Security Package'><a href="/product/total_security_package?hl=en-US" jsaction="click:ufFX6e;" class="sWgry" aria-label="Security Package" data-tracking-module-name="mobile-nav-tray-section-Discover" data-tracking-label="section-detailed:Security Package:3" data-tracking-index="3" data-tracking-action="/category/connected_home&gt;&gt;/product/total_security_package" data-tracking-url="/product/total_security_package"><div data-component-name="box" class="gQjUFd NGrerf fXTCsc UiYyRd" style="padding:8px;border-radius:24px"><article class="ri9Fr"><aside class="oTSVsc"><span class="BhjvRe">Security Package</span><span class="eUe8V">Nest helps you ensure your home is covered with ease. Pair the Nest Doorbell and Nest Cam with the Nest Hub Max to get a better picture of what’s happening in and around your home.</span></aside><aside class="oTSVsc"><span class="rIbWHd"
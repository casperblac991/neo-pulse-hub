ull,"",null,null,null,"Buy Pixel 10 Pro Fold",null,null,null,null,null,"pixel_10_pro_fold"]]]],[null,null,null,null,[null,"onRequest"]]]],28],["Watches and Trackers | Spacer Medium 8 | Summer 2025 |",null,null,null,null,"gsins_4347_8357",null,null,null,null,null,[[null,null,"medium"]],29],["Watches and Trackers | Fitbit Enterprise | Summer 2025 |",null,null,null,null,"gsins_1706_3877",null,null,null,null,null,[null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,[null,"fitbit-enterprise",null,null,null,[[["https://lh3.googleusercontent.com/LpJ52TOlyZPrd4nYkecu51js7fmIkjyF6foRDaPbOoS4UIwv3M7ubOgba-mKV5q_0z58GLOsI5Yt0U6n7FJe2TJrSFu2uBIzALvb",["lg-gt-only","rounded-corners"],"Close-up shot of a person wearing a Google Pixel watch on their wrist.",[1604,1280]]],[["https://lh3.googleusercontent.com/7x2Q1vtagQkNnQOeeObH2K4KPU0ivHsIixQhvQowUmEr4WCun6xQWSWfd2bKgDS4jK_0FiC9eqjl7ZsM-EHMJZl3cD6443K56A",["md-lt-only","rounded-corners"],"Close-up shot of a person wearing a Google Pixel watch on their wrist.",[656,820]]]],null,null,[null,null,[null,"Power your population health programs with Fitbit Enterprise."],null,["headline-small"],[[null,"https://fitbit.google/enterprise/?utm_source\u003dgStore\u0026utm_medium\u003dweb\u0026utm_campaign\u003dUS_watches_trackers_page_banner",null,"Learn more",null,"Learn more about Fitbit Enterprise",null,["ds-low-emphasis"]]]]]],30],["Watches and Trackers | Spacer Medium 9 | Summer 2025 |",null,null,null,null,"gsins_3143_0773",null,null,null,null,null,[[null,null,"medium"]],31],["Watches and Trackers | Benefits Intro | Summer 2025 |",null,null,null,null,"gsins_9075_5049",null,null,null,null,null,[null,null,null,null,null,["benefits-intro",["display-medium","left-aligned"],null,null,null,null,[null,"There’s no better place to buy a Pixel Watch."],null,null,null,["left"]]],32],["Watches and Trackers | Spacer Small 7 | Summer 2025 |",null,null,null,null,"gsins_6980_7731",null,null,null,null,null,[[null,"spacer-small","small"]],33],["Watches and Trackers | Benefits Slider | Summer 2025 |",null,null,null,null,"gsins_6442_5675",null,null,null,null,[null,null,0],[null,null,null,null,null,null,null,null,null,null,null,null,null,[["headline-small"],"benefits-slider",[null,null,0],null,null,[["medium","#F3F3F3",null,1,0,null,[null,["https://storage.googleapis.com/mannequin/blobs/ebdcaa2f-1a07-402f-9d7c-7100a425f414.svg"],[null,"Trade in your old watch and save.\u003csup data-footnote\u003d\"trade-in\"\u003e\u003c/sup\u003e"],null,[[null,"/magazine/trade_in",null,"Learn more",null,"Learn more about trade-in",null,["ds-low-emphasis"]]]]],["medium","#F3F3F3",null,1,0,null,[null,["https://storage.googleapis.com/mannequin/blobs/a2bf35da-f3f0-4fc8-89a9-af4a66cf1d9b.svg",null,[48,48]],[null,"Pixel Care+ for added protection."],null,[[null,"/magazine/preferred_care",null,"Learn more",null,"Learn more about Pixel Care+",null,["ds-low-emphasis"]]]]],["medium","#F3F3F3",null,1,0,null,[null,["https://storage.googleapis.com/mannequin/retail-qualifiers/financing.svg"],[null,"Finance your watch or tracker."],null,[[null,"/magazine/financing",null,"Learn more",null,"Learn more about financing watches and trackers.",null,["ds-low-emphasis"]]]]],["medium","#F3F3F3",null,1,null,null,[null,["https://storage.googleapis.com/mannequin/retail-qualifiers/free-shipping.svg"],[null,"Free shipping and returns.\u003csup data-footnote\u003d\"shipping\"\u003e\u003c/sup\u003e"],null,[[null,"https://support.google.com/store/answer/12436460",null,"Learn more",null,"Learn more about free shipping and returns",null,["ds-low-emphasis"]]]]]],null,null,["left"]]],34],["Watches and Trackers | Spacer Medium 10 | Summer 2025 |",null,null,null,null,"gsins_2409_0128",null,null,null,null,null,[[null,null,"medium"]],35],["Watches and Trackers | Footnotes | Summer 2025 |",null,null,null,null,"gsins_5081_9002",null,null,null,null,null,[null,null,null,[null,"footnotes",1,"Footnotes",null,[["1","compatibility",[null,"Works with most phones running on Android 11.0 or newer. Requires Google Account, Google Pixel Watch app, and internet access. Some features require a Fitbit mobile app and/or paid subscription. Google apps and services and Fitbit Premium content and features are subject to change and may not be available in all countries or languages. Google Pixel Watch is not compatible with Android (Go edition). See \u003ca href\u003d\"https://g.co/pixelwatch/specs\" target\u003d\"_blank\"\u003eg.co/pixelwatch/specs\u003c/a\u003e for technical and device specifications."]],["2","fitbit",[null,"Requires Fitbit mobile app, a Google Account, compatible Android device, and internet connection.  Fitbit Premium content and features may change. Content recommendations are not available in all countries and may be in English only."]],["3","ace-pass",[null,"Ace Pass data plan required. Works with most phones running Android 11.0 or newer or iOS 15 or newer. Requires Wi-Fi for setup. Setup for users under 13 requires parent and child Google Accounts, and parent’s use of Fitbit Ace app on parent’s compatible phone. Older users require Google Account and Fitbit Ace app on user’s compatible phone. See g.co/fitbitace/info for more information."]],["4","fitbit-premium",[null,"With eligible device purchase. New and returning Fitbit Premium members only. Must activate membership within 60 days of device activation. Valid form of payment required. After the 6-month period, subscription will renew at $9.99 monthly or $79.99 annually (based on your registration). Cancel anytime. Membership cannot be gifted. Content and features may change. See g.co/fitbitpremium/help for more details. Full terms: \u003ca href\u003d\"https://g.co/pixelwatch/fitbitpremium-tos\" target\u003d\"_blank\"\u003eg.co/pixelwatch/fitbitpremium-tos.\u003c/a\u003e"]],["5","lte",[null,"Google apps and services require LTE or a paired phone within Bluetooth range of your device and are not available in all countries or languages. Data rates may apply."]],["Δ","trade-in",[null,"Trade-in values vary based on condition, year, and configuration of your eligible device, and are subject to change upon inspection. Watch trade-in credit will be issued as a refund back on the specific form of payment used for the watch purchase at Google Store or in the form of Store Credit if the purchased watch has already been returned. Refund is based on (and paid after) watch received matching the description provided at time of estimate. Watches sent for trade-in must be received within 30 days of initiation of trade-in process, provided the purchased device has not been returned during that time. Additional trade-in terms are located here: \u003ca href\u003d\"https://store.google.com/intl/en-US_us/about/device-trade-in.html\" target\u003d\"_blank\"\u003estore.google.com/intl/en-US_us/about/device-trade-in.html\u003c/a\u003e"]],["†","shipping",[null,"All orders that ship free use the lowest-cost option unless otherwise noted. All free returns must be initiated within 15 days of receipt of order by following the instructions found \u003ca href\u003d\"https://support.google.com/store/answer/2411741?sjid\u003d8998094188717530883-NC\" target\u003d\"_blank\"\u003ehere\u003c/a\u003e."]]]]],36],["Watches and Trackers | Spacer Small 8 | Summer 2025 |",null,null,null,null,"gsins_1204_2544",null,null,null,null,null,[[null,"spacer-small","small"]],37],["CRM pop-up - anchored - No incentive - US (infinity)",null,null,null,null,"gsins_9031_3264",null,null,null,null,null,[null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,[null,"crm_popup_anchored",null,["incentivePopupAnchored","incentivePopupAnchored",1,1,10,0,null,null,0],["popup_bottom_evergreen-",null,null,null,1,[[null,"Sign in and sign up"],"Sign in and sign up for news and offers",[null,"or enter email address"],"or enter email address","Email address","Submit","Email address contains error(s).",null,null,["ds-mid-emphasis-grey"]],[[null,"Sign up"],"Sign up for news and offers"],[[null,"You're subscribed"]],[null,"Something went wrong, please refresh and try again."]],null,[[null,""],[null,"Be the first to know about Google Store news, tips, and offers."]],[[null,""],[null,"You're now ready to receive the latest news and offers from the Google Store."]],"Continue browsing",null,null,null,[null,null,null,null,[null,"onRequest"]]]],38]]],null,[],[1,"Find your fit with Google Fitbit's family of fitness trackers and smartwatches that help you stay motivated and improve your health by tracking your activity, exercise, food, weight and sleep.","Fitbit Official Site for Activity Trackers \u0026 Smartwatches","fitbit, trackers, smartwatches, health, activity",null,["Fitbit Activity Trackers \u0026 Smartwatches","Stay motivated and improve your health by tracking your activity, exercise, food, weight and sleep.","https://lh3.googleusercontent.com/I7TOyZ4Km4pcDQhrNkcFcwx9XrFRx41-upct8LUkvEuE1R2FZC3JYwgWcbRQb5qBX-ToRd1Xmkuun4vN14h6dCJ133SoP2rqvg",null,1]],null,null,0,1], sideChannel: {}});</script><script id="wiz_jd" nonce="2kyhPuSkrJx-YUklyV6aYg">if (window['_wjdc']) {const wjd = {'180': JSON.parse('\x5bnull,2\x5d'),'181': JSON.parse('\x5b\x22SOURCE:STORE_IPH|NAV_CONTEXT:CATEGORY_PAGE|DOC_ID:watches_trackers\x22\x5d'),}; window['_wjdc'](wjd); delete window['_wjdc'];}</script><script aria-hidden="true" id="WIZ-footer" nonce="2kyhPuSkrJx-YUklyV6aYg">window.wiz_progress&&window.wiz_progress();window.stopScanForCss&&window.stopScanForCss(); ccTick('